# =============================================================================
# Aether - Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local or any file containing secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL - required for Vercel/Production)
# -----------------------------------------------------------------------------
# Local: use a PostgreSQL URL or leave as below and run PostgreSQL locally.
# Vercel/Neon: set DATABASE_URL and optionally DIRECT_DATABASE_URL for migrations.
DATABASE_URL="postgresql://user:password@localhost:5432/aether?schema=public"
# DIRECT_DATABASE_URL="postgresql://..."  # Optional; required for some hosted DBs

# -----------------------------------------------------------------------------
# Auth.js (NextAuth)
# -----------------------------------------------------------------------------
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
# OAuth providers (optional - uncomment and configure as needed)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""

# -----------------------------------------------------------------------------
# Stripe (Billing)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
