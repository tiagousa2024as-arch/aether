# =============================================================================
# Aether - Environment Configuration
# =============================================================================
# Copy to .env or .env.local (local) or set in Vercel Project Settings (production).
# Never commit real secrets. Never paste API keys in code or chat — revoke if exposed.
# Required for deploy: DATABASE_URL, AUTH_SECRET.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL - required)
# -----------------------------------------------------------------------------
# Vercel/Neon: set DATABASE_URL in Vercel env. Use pooler URL for serverless.
DATABASE_URL="postgresql://user:password@localhost:5432/aether?schema=public"
# DIRECT_DATABASE_URL="postgresql://..."  # Optional; for migrations on Neon

# -----------------------------------------------------------------------------
# Auth.js (NextAuth) - required
# -----------------------------------------------------------------------------
# Generate: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Production: set AUTH_URL to your app URL (e.g. https://yourapp.vercel.app).
# On Vercel, AUTH_URL is optional when trustHost is true (uses VERCEL_URL).
AUTH_URL="http://localhost:3000"
# OAuth (optional - leave unset to disable)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""

# -----------------------------------------------------------------------------
# Stripe (optional - billing works only when keys are set)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# -----------------------------------------------------------------------------
# LLM & Integrations (AETHER MVP: Commands → OpenAI → Salesforce + Teams)
# -----------------------------------------------------------------------------
# Required for command interpretation (POST /api/commands)
OPENAI_API_KEY="sk-..."

# Anthropic (optional)
# ANTHROPIC_API_KEY="sk-ant-..."

# Microsoft Graph (for Teams messages)
# MICROSOFT_CLIENT_ID=""
# MICROSOFT_CLIENT_SECRET=""
# MICROSOFT_TENANT_ID=""
# MICROSOFT_TEAMS_TEAM_ID=""
# MICROSOFT_TEAMS_CHANNEL_ID=""

# Salesforce (Lead creation)
# Option A: direct token (simplest)
# SALESFORCE_ACCESS_TOKEN=""
# SALESFORCE_INSTANCE_URL="https://yourorg.my.salesforce.com"
# Option B: OAuth2 username-password (SALESFORCE_INSTANCE_URL optional)
# SALESFORCE_CLIENT_ID=""
# SALESFORCE_CLIENT_SECRET=""
# SALESFORCE_USERNAME=""
# SALESFORCE_PASSWORD=""
# SALESFORCE_INSTANCE_URL="https://yourorg.my.salesforce.com"

# ServiceNow
# SERVICENOW_INSTANCE="https://your-instance.service-now.com"
# SERVICENOW_USERNAME=""
# SERVICENOW_PASSWORD=""

# -----------------------------------------------------------------------------
# Application (optional)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
